# Rename this file to ".env" and restart Expo with:  npx expo start -c
#
# Your project URL is built from your project ref (hawywakiessppitljpzl),
# NOT the dashboard link. This is already correct below.
EXPO_PUBLIC_SUPABASE_URL=https://hawywakiessppitljpzl.supabase.co

# Paste your key from the dashboard: Settings -> API Keys.
#   - Legacy projects: copy the "anon" "public" key (starts with eyJ...)
#   - Newer projects:  copy the "Publishable key" (starts with sb_publishable_...)
# Either one is safe to ship in the app. NEVER use the service_role / secret key here.
EXPO_PUBLIC_SUPABASE_ANON_KEY=paste_your_anon_or_publishable_key_here
